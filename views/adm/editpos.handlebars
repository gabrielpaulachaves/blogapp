<h2>Editando postagem</h2>
<hr>
    <div class="card mt-4">
        <div class="card-body">
        <form action="/admin/post/edit"  method="post">
        <input type="hidden" name="id" value="{{postagem._id}}">
        <label for="titulo">Título: </label>
        <input type="text" name="titulo" id="titulo" class="form-control" value="{{postagem.titulo}}">
        <label for="slug">Slug: </label>
        <input type="text" name="slug" id="slug" placeholder="Slug do post" class="form-control" value="{{postagem.slug}}">
        <label for="descricao">Descrição do post: </label>
        <input type="text" name="descricao" id="descricao" class="form-control" value="{{postagem.descricao}}">
        <label for="conteudo">Conteúdo: </label>
        <textarea name="conteudo" id="conteudo" class="form-control">{{postagem.conteudo}}</textarea>
        <label for="categoria">Categoria referente: </label>
        <select name="categoria" id="categoria" class="form-select">
            {{#each categoria}}
            <option value="{{_id}}">{{nome}}</option>
            {{else}}
                <option value="0">Nenhuma categoria registrada</option>
            {{/each}}
        </select>
        <a href=""><button class="btn btn-success mt-4" type="submit">Salvar</button></a>
        </form>
        </div>
    </div>

