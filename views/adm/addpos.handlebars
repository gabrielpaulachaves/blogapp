{{#each erros}}
        <div class="alert alert-danger">{{texto}}</div>
{{else}}

{{/each}}
<h2>Realizando nova postagem</h2>
<div class="card">
    <div class="card-body">
        <form action="/admin/post/nova"  method="post">
        <label for="titulo">Título: </label>
        <input type="text" name="titulo" id="titulo" class="form-control">
        <label for="slug">Slug: </label>
        <input type="text" name="slug" id="slug" placeholder="Slug do post" class="form-control">
        <label for="descricao">Descrição do post: </label>
        <input type="text" name="descricao" id="descricao" class="form-control">
        <label for="conteudo">Conteúdo: </label>
        <textarea name="conteudo" id="conteudo" class="form-control"></textarea>
        <label for="categoria">Categoria referente: </label>
        <select name="categoria" id="categoria" class="form-select">
            {{#each cat}}
            <option value="{{_id}}">{{nome}}</option>
            {{else }}
                <option value="0">Nenhuma categoria registrada</option>
            {{/each}}
        </select>
        <button class="btn btn-success mt-4" type="submit">Criar</button>
        </form>
    </div>
</div>